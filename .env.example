# =========================================================================
# CareerZen AI Platform - Configurable Environment Variables
# =========================================================================

# Database Configuration (Prisma ORM)
# -------------------------------------------------------------------------
# By default, SQLite is configured in prisma/schema.prisma for zero-setup local development:
# DATABASE_URL="file:./dev.db"
#
# To scale to PostgreSQL or Supabase in production:
# 1. Update provider to "postgresql" in prisma/schema.prisma
# 2. Configure DATABASE_URL below:
DATABASE_URL="postgresql://postgres:password@localhost:5432/careerzen?schema=public"

# Authentication & Security
# -------------------------------------------------------------------------
# Secret used to encode/decode database credentials JWT cookies:
JWT_SECRET="careerzen-ai-super-secret-key-2026"

# AI Integrations (OpenAI & Gemini APIs)
# -------------------------------------------------------------------------
# Add your premium API keys below to unlock live real-time AI responses.
# If left blank, the platform seamlessly switches to a highly realistic mock Smart AI Engine.
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Cloud Storage (Cloudinary Uploads)
# -------------------------------------------------------------------------
# Used to support secure file uploads (resumes/avatars):
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
